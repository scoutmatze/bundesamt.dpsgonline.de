generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  role          String    @default("USER")
  emailVerified DateTime?
  name          String?
  title         String?
  firstName     String?
  lastName      String?
  street        String?
  zipCode       String?
  city          String?
  ibanEncrypted String?   @db.Text // AES-256-GCM encrypted
  bic           String?
  bank          String?
  gremium       String?
  password      String?
  accountHolder String?
  signaturePath String?   // Path in MinIO
  signatureData   String?   // Canvas-Signatur als Data URL
  kmRate        Float     @default(0.20)
  image         String?   // NextAuth default

  accounts Account[]
  sessions Session[]
  trips    Trip[]
  sachkosten      Sachkosten[]
  bewirtungen     Bewirtung[]
  bahncards       BahnCard[]
  inbox         InboxItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trip {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  purpose      String
  route        String?
  notes           String?
  startTime       String?
  endTime         String?
  verpflegungAmount Float?   @default(0)
  verpflegungData String?
  kmRate          Float?   @default(0.30)
  kmLegs          String?
  kmTotal         Int?     @default(0)
  kmAmount        Float?   @default(0)
  bewirtungen     Bewirtung[]
  startDate    DateTime
  endDate      DateTime?
  travelMode   TravelMode @default(BAHN)
  pkwReason    String?
  licensePlate String?
  mietwagenApproved Boolean? @default(false)
  isElectric    Boolean? @default(false)
  co2Offset    Boolean    @default(false)

  status       TripStatus @default(DRAFT)
  submittedAt  DateTime?
  pdfPath      String?    // Generated PDF in MinIO

  receipts Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, startDate])
}

model Receipt {
  id            String          @id @default(cuid())
  tripId        String
  trip          Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)

  description   String?
  amount        Float
  date          DateTime
  category      ReceiptCategory
  fromStation   String?
  toStation     String?
  isHandyticket Boolean         @default(false)

  fileName      String?
  filePath      String?         // Path in MinIO
  mimeType      String?
  fileSize      Int?

  createdAt DateTime @default(now())

  @@index([tripId])
}

enum TravelMode {
  BAHN
  PRIVAT_PKW
  DIENSTWAGEN
  FLUGZEUG
  FAHRRAD
  MIETWAGEN
}

enum TripStatus {
  DRAFT
  READY
  SUBMITTED
  ARCHIVED
}

enum ReceiptCategory {
  FAHRT
  UNTERKUNFT
  VERPFLEGUNG
  NEBENKOSTEN
}

model LoginCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Sachkosten {
  id        String           @id
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  year      Int
  quarter   Int
  status    String           @default("DRAFT")
  notes     String?
  items     SachkostenItem[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  @@unique([userId, year, quarter])
}

model SachkostenItem {
  id           String     @id
  sachkostenId String
  sachkosten   Sachkosten @relation(fields: [sachkostenId], references: [id], onDelete: Cascade)
  date         DateTime
  description  String
  amount       Float      @default(0)
  fileName     String?
  filePath     String?
  createdAt    DateTime   @default(now())
}

model Bewirtung {
  id           String   @id
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripId       String?
  trip         Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  date         DateTime
  location     String
  occasion     String
  participants String
  amountFood   Float    @default(0)
  amountDrinks Float    @default(0)
  amountTip    Float    @default(0)
  amountTotal  Float    @default(0)
  notes        String?
  fileName     String?
  filePath     String?
  status       String   @default("DRAFT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BahnCard {
  id            String    @id
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  year          Int
  cardType      String    @default("BC50")
  class         Int       @default(2)
  cost          Float     @default(0)
  validFrom     DateTime?
  validTo       DateTime?
  bahnCardNr    String?
  justification String?
  notes         String?
  status        String    @default("DRAFT")
  fileName      String?
  filePath      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@unique([userId, year])
}

model InboxItem {
  id           String   @id
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName     String
  filePath     String
  mimeType     String?
  fileSize     Int?
  subject      String?
  preview      String?
  assignedTo   String?
  assignedType String?
  status       String   @default("NEW")
  createdAt    DateTime @default(now())
}
