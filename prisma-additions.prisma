// ── Zum bestehenden Trip-Model hinzufügen: ──
//   startTime           String?
//   endTime             String?
//   verpflegungAmount   Float?     @default(0)
//   verpflegungData     String?    // JSON
//   kmRate              Float?     @default(0.30)
